{
  "name": "uc-controls",
  "version": "1.0.4",
  "type": "module",
  "exports": {
    "./*": "./out/*",
    "./package.json": "./package.json"
  },
  "description": "Reusable UI controls for UC-based Electron applications",
  "scripts": {
    "clean": "rimraf dist",
    "start": "electron .",
    "build:designer": "uc-dev build",
    "build:dts": "tsc --emitDeclarationOnly",
    "build": "tsc",
    "rebuild": "npm run clean && npm run build:designer && npm run build && npm run build:dts",
    "rebuild:start": "npm run rebuild && npm run start"
  },
  "author": "ap",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.2",
    "rimraf": "^6.0.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "uc-runtime": "^3.0.4"
  },
  "keywords": [
    "usercontrols",
    "ucs",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pratik2201/uc-controls.git"
  },
  "bugs": {
    "url": "https://github.com/pratik2201/uc-controls/issues"
  },
  "homepage": "https://github.com/pratik2201/uc-controls#readme"
}
